# =====================
# PayPal configuration
# Required for PayPal transaction endpoints
# =====================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Frontend URL used by backend when generating PayPal return/cancel links
FRONTEND_URL=http://localhost:3000

# =====================
# Email notification configuration (optional but recommended)
# Used by EmailService for order status notifications
# =====================
EMAIL_ADDRESS=your_gmail_address@gmail.com
EMAIL_PASSWORD=
APP_PASSWORD=your_gmail_app_password

# =====================
# Chatbot/Ollama configuration
# In Docker Compose this defaults to http://ollama:11434
# =====================
OLLAMA_URL=http://ollama:11434

# =====================
# Frontend runtime overrides (optional)
# =====================
VITE_API_URL=/api
VITE_POPULAR_RESTAURANTS_ENDPOINT=/restaurants/popular
VITE_RECENT_RESTAURANTS_ENDPOINT=/restaurants/recent